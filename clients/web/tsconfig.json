{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"],
    "paths": {
      // Map the real WASM module path (generated by `npm run prepare-wasm`
      // into the gitignored core/bindings/wasm/pkg/) to committed type
      // declarations in src/wasm-bindings.d.ts.  This lets `tsc --noEmit`
      // resolve types on a fresh checkout that has not yet built the WASM.
      "../../../core/bindings/wasm/pkg/index.js": ["./src/wasm-bindings.d.ts"]
    }
  },
  "include": ["src", "tests"]
}
